# Site URL (SEO, Open Graph). Replace with your production domain.
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Electron build: app opens this URL when packaged (domain mode).
SITE_URL=https://yourdomain.com

# Dev / Electron server port (default: 3004)
PORT=3004


# Set by runtime (do not add here): NODE_ENV, VERCEL
